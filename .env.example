# Database Settings
# For SQLite local development: file:./dev.db (Next.js) or sqlite:///../frontend/prisma/dev.db (FastAPI)
# For production PostgreSQL: postgresql://user:password@localhost:5432/clipforge
DATABASE_URL="file:./dev.db"

# Gemini API Key (Required for AI analysis)
GEMINI_API_KEY="your-gemini-api-key-here"

# Authentication Settings
NEXTAUTH_SECRET="your-nextauth-secret-here-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Backend API Settings
BACKEND_URL="http://localhost:8000"

# Celery & Queue Settings
# For local development without Redis, Celery will use SQLite: sqla+sqlite:///../frontend/prisma/celery.db
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# Storage Settings (local or s3)
STORAGE_TYPE="local"
S3_ENDPOINT="https://s3.us-east-1.amazonaws.com"
S3_ACCESS_KEY="your-s3-access-key"
S3_SECRET_KEY="your-s3-secret-key"
S3_BUCKET_NAME="clipforge-media"

# Next.js Public Vars
NEXT_PUBLIC_API_URL="http://localhost:8000"
